{
  "name": "@bluvo/sdk",
  "private": true,
  "scripts": {
    "complete-sync": "pnpm generate-sdk && pnpm --filter @bluvo/sdk-ts build && pnpm --filter @bluvo/react build",
    "generate-sdk": "openapi-ts",
    "complete-sync-test": "pnpm generate-sdk-test && pnpm --filter @bluvo/sdk-ts build && pnpm --filter @bluvo/react build",
    "generate-sdk-test": "openapi-ts --file openapi-ts.test.config.ts",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@hey-api/openapi-ts": "^0.86.8",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@gomomento/sdk-web": "^1.113.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
